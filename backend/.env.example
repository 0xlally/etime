# Application Configuration
APP_NAME=FastAPI Application
APP_VERSION=1.0.0
DEBUG=True

# Database Configuration
# Local development default
DATABASE_URL=sqlite:///./app.db

# Postgres example (Docker Compose injects DATABASE_URL from the root .env values)
# DATABASE_URL=postgresql+psycopg2://etime:<strong-password>@db:5432/etime

# SQLite example:
# DATABASE_URL=sqlite:///./app.db

# MySQL example:
# DATABASE_URL=mysql+pymysql://username:password@localhost:3306/dbname

# Security
JWT_SECRET=your-super-secret-key-change-this-in-production-use-long-random-string
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=43200
REFRESH_TOKEN_EXPIRE_DAYS=7
LOGIN_RATE_LIMIT_MAX_ATTEMPTS=20
LOGIN_RATE_LIMIT_WINDOW_SECONDS=300
PASSWORD_RESET_RATE_LIMIT_MAX_ATTEMPTS=5
PASSWORD_RESET_RATE_LIMIT_WINDOW_SECONDS=900

# Database bootstrap / admin seed
AUTO_CREATE_TABLES=True
AUTO_INIT_ADMIN=False
DEFAULT_ADMIN_EMAIL=admin@example.com
DEFAULT_ADMIN_USERNAME=admin
# Only set when AUTO_INIT_ADMIN=True. Must be at least 12 chars and not a known default.
DEFAULT_ADMIN_PASSWORD=

# CORS Origins (comma-separated)
BACKEND_CORS_ORIGINS=["http://localhost:3000","http://localhost:8000","http://localhost","https://localhost","capacitor://localhost"]

# API Configuration
API_V1_PREFIX=/api/v1

# SMTP / Email
# Required for forgot-password emails. The API intentionally returns a generic
# response even if mail delivery fails, so check backend logs after configuring.
SMTP_HOST=
SMTP_PORT=465
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
SMTP_TLS=False
SMTP_SSL=True
